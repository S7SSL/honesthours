{
  "manifest_version": 3,
  "name": "Honest Hours",
  "version": "1.0.0",
  "description": "WFH time tracking built on trust, not surveillance.",
  "permissions": ["storage", "alarms", "idle", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
